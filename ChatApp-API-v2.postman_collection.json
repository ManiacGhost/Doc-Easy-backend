{
  "info": {
    "_postman_id": "chatapp-v2",
    "name": "ChatApp API v2",
    "description": "Enhanced Chatapp API with improved logging and debugging",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Assets",
      "item": [
        {
          "name": "Upload Asset",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "http://localhost:8080/api/assets/upload",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "assets",
                "upload"
              ]
            },
            "description": "Upload a new asset (PDF, Image, Audio, or Video)"
          },
          "response": []
        },
        {
          "name": "List All Assets",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/assets",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "assets"
              ]
            },
            "description": "Get list of all uploaded assets"
          },
          "response": []
        },
        {
          "name": "Get Asset Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/assets/1",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "assets",
                "1"
              ]
