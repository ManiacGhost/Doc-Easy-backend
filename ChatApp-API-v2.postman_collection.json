          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/assets/1/summary",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "assets",
                "1",
                "summary"
              ]
            },
            "description": "Get summary of an asset using AI"
          },
          "response": []
        },
        {
          "name": "Ask Question",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \\\"question\\\": \\\"What is the main topic of this content?\\\"\\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/assets/1/ask",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "assets",
                "1",
                "ask"
              ]
            },
            "description": "Ask a question about an asset"
          },
          "response": []
        },
        {
          "name": "Find Topic Timestamps",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/assets/1/timestamps?topic=technology",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "assets",
                "1",
                "timestamps"
              ],
              "query": [
                {
                  "key": "topic",
                  "value": "technology"
                }
              ]
            },
            "description": "Get timestamps for a specific topic (mainly for videos)"
          },
          "response": []
        },
        {
          "name": "Stream Asset",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/assets/1/stream?startSeconds=0",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "assets",
                "1",
                "stream"
              ],
              "query": [
                {
                  "key": "startSeconds",
                  "value": "0"
                }
              ]
            },
            "description": "Stream video/audio from a specific timestamp"
          },
          "response": []
        }
